# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_TELEGRAM_ID=
WEBHOOK_BASE_URL=https://noteturner.onrender.com
BOT_MODE=webhook

# Database (Render provides DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/noteturner

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEST_MODEL=openai/gpt-5-nano

# Embeddings (via OpenRouter /embeddings)
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Hollihop CRM
HOLLIHOP_SUBDOMAIN=
HOLLIHOP_AUTH_KEY=

# Google Drive knowledge source
# ID of the shared folder (from its URL) and the FULL service account JSON key (one line).
GDRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
